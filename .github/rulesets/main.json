{
  "name": "Protect main",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"]
    }
  },
  "rules": [
    {
      "type": "required_status_checks",
      "parameters": {
        "required_status_checks": [
          { "context": "CI / build" },
          { "context": "CI / semantic-pull-request" }
        ],
        "strict_required_status_checks_policy": false
      }
    },
    { "type": "non_fast_forward" },
    { "type": "deletion" }
  ]
}
