# Binaries
*.exe
*.dll
*.so
*.dylib
*.test
/sandman

# Output of the go coverage tool
*.out
coverage.html

# Dependency directories
vendor/

# Go workspace file
go.work

# Sandman runtime state
.sandman/
# Per-checkout control file written by the badge sidecar when the Built
# with Sandman badge PR is created. .sandman/ already covers it; the
# explicit line keeps the intent obvious for readers scanning .gitignore.
.sandman/.built_with_sandman

# Environment files
.env
.env.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Codeindex generated files
codeindex.json
symbolindex.json

# Node.js
node_modules/
package.json
package-lock.json

# Worktrees
.worktrees/

# Token optimizer sessions
token-optimizer/

# Test fixtures and test-only artifacts produced locally by go test (perf
# baselines, ad-hoc test reports). The portal perf tests write JSON
# baselines under testdata/portal_perf_baseline/ on every run; they are
# reproducible from a test invocation and should not be tracked.
testdata/
TEST_REPORT.md

# OpenCode sessions
.opencode/

# Review state files
*.addressed_comments

# OS
.DS_Store
Thumbs.db
codeindex.json
symbolindex.json
